{
	"schemaVersion": 1,
	"id": "starbond",
	"version": "${version}",
	"name": "Starbond",
	"description": "This is an example description! Tell everyone what your mod is about!",
	"authors": [
		"Me!"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/starbond/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"io.github.bigcrazyofficial.Starbond"
		],
		"client": [
			"io.github.bigcrazyofficial.client.StarbondClient"
		],
		"fabric-datagen": [
			"io.github.bigcrazyofficial.client.StarbondDataGenerator"
		],
		"cardinal-components": [
			"io.github.bigcrazyofficial.data.CardinalComponents"
		]
	},
	"mixins": [
		"starbond.mixins.json",
		{
			"config": "starbond.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.6",
		"minecraft": "~26.1.2",
		"java": ">=25",
		"fabric-api": "*"
	},
	"custom": {
		"cardinal-components": [
			"starbond:bond_id",
			"starbond:bond"
